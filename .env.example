# Copy this file to .env and fill in real values. .env is gitignored.
# All variables are optional unless noted; defaults shown.

# Backend server bind
DEPOPRO_HOST=127.0.0.1
DEPOPRO_PORT=8765

# Set to 1 to enable DevTools, verbose logging, and FastAPI access logs
DEPOPRO_DEBUG=0

# Transcription provider:
#   deepgram = use live Deepgram when DEEPGRAM_API_KEY is set
#   offline  = force deterministic offline validation transcripts
DEPOPRO_TRANSCRIPTION_PROVIDER=deepgram

# Deepgram API key (required for Phase B.3 transcription)
DEEPGRAM_API_KEY=
